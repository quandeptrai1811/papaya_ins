{
  "country": "vietnam",
  "rules": [
    {
      "rule_id": "VN-DOC-01",
      "description": "Medical receipt is required for all claim types in Vietnam",
      "rule_type": "document_requirement",
      "parameters": {
        "required_documents": ["medical_receipt"],
        "applies_to_claim_types": ["outpatient", "inpatient", "dental", "specialist", "maternity", "emergency"]
      },
      "effective_date": "2023-01-01",
      "expiry_date": null
    },
    {
      "rule_id": "VN-DOC-02",
      "description": "Hospital certificate is required for all inpatient claims in Vietnam",
      "rule_type": "document_requirement",
      "parameters": {
        "required_documents": ["hospital_certificate"],
        "applies_to_claim_types": ["inpatient"]
      },
      "effective_date": "2023-01-01",
      "expiry_date": null
    },
    {
      "rule_id": "VN-DOC-03",
      "description": "ID card copy is required for all claim types in Vietnam",
      "rule_type": "document_requirement",
      "parameters": {
        "required_documents": ["id_card_copy"],
        "applies_to_claim_types": ["outpatient", "inpatient", "dental", "specialist", "maternity", "emergency"]
      },
      "effective_date": "2023-01-01",
      "expiry_date": null
    },
    {
      "rule_id": "VN-SLA-01",
      "description": "All claims must be processed within 10 business days in Vietnam",
      "rule_type": "sla_check",
      "parameters": {
        "sla_business_days": 10,
        "sla_claim_types": ["outpatient", "inpatient", "dental", "specialist", "maternity", "emergency"]
      },
      "effective_date": "2023-01-01",
      "expiry_date": null
    },
    {
      "rule_id": "VN-WAIT-01",
      "description": "General waiting period is 30 days; pre-existing conditions have a 365-day waiting period in Vietnam",
      "rule_type": "waiting_period",
      "parameters": {
        "waiting_days_general": 30,
        "waiting_days_preexisting": 365
      },
      "effective_date": "2023-01-01",
      "expiry_date": null
    },
    {
      "rule_id": "VN-MASK-01",
      "description": "Full name must be masked in external reports in Vietnam — show first and last initials only",
      "rule_type": "data_masking",
      "parameters": {
        "field": "member_name",
        "mask_strategy": "initials"
      },
      "effective_date": "2023-01-01",
      "expiry_date": null
    },
    {
      "rule_id": "VN-COV-01",
      "description": "Maternity must be covered for policies older than 12 months in Vietnam",
      "rule_type": "coverage_mandate",
      "parameters": {
        "mandate_type": "maternity_coverage",
        "condition": "policy_age_months > 12"
      },
      "effective_date": "2023-06-01",
      "expiry_date": null
    }
  ]
}
